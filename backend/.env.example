# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Z.AI API (OpenAI-compatible)
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# Z.AI Models (change these to test different models)
ZAI_SCENARIO_MODEL=glm-5
ZAI_AGENT_MODEL=glm-4.7
ZAI_FAST_MODEL=glm-5
ZAI_VISION_MODEL=glm-4.6v
ZAI_OCR_MODEL=glm-ocr

# LiveKit (required for backend-managed LiveKit voice transport)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ElevenLabs (required when VOICE_BACKEND=livekit_elevenlabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_STT_MODEL=scribe_v2_realtime
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5

# Firestore
FIRESTORE_EMULATOR_HOST=localhost:8080  # Set only for local dev

# FastAPI
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development  # "development" uses local storage, "production" uses Firebase
VOICE_BACKEND=livekit_elevenlabs
SINGLE_AGENT_VOICE_MODE=false
MAX_AGENTS_PER_SESSION=4

# Pub/Sub
PUBSUB_EMULATOR_HOST=localhost:8085  # Set only for local dev
PUBSUB_TOPIC=war-room-events
